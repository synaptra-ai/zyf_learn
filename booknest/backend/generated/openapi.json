                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/books/{id}": {
      "put": {
        "summary": "更新书籍",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
